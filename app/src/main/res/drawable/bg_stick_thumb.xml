<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#2A2A2A" />
        </shape>
    </item>
    <!-- Textured surface -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="oval">
            <solid android:color="#222222" />
            <stroke
                android:width="1dp"
                android:color="#444444" />
        </shape>
    </item>
</layer-list>
