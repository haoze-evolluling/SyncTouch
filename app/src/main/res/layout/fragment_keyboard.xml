<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="@dimen/keyboard_total_height"
    android:layout_gravity="top"
    android:orientation="vertical"
    android:paddingStart="@dimen/keyboard_padding"
    android:paddingEnd="@dimen/keyboard_padding_end"
    android:paddingTop="@dimen/keyboard_padding"
    android:paddingBottom="36dp"
    android:gravity="top">

    <!-- Row 0: Number row -->
    <LinearLayout
        android:id="@+id/keyboard_row_0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/keyboard_row_spacing" />

    <!-- Row 1: QWERTY row -->
    <LinearLayout
        android:id="@+id/keyboard_row_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/keyboard_row_spacing" />

    <!-- Row 2: ASDF row -->
    <LinearLayout
        android:id="@+id/keyboard_row_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/keyboard_row_spacing" />

    <!-- Row 3: ZXCV row -->
    <LinearLayout
        android:id="@+id/keyboard_row_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/keyboard_row_spacing" />

    <!-- Row 4: Bottom modifier row -->
    <LinearLayout
        android:id="@+id/keyboard_row_4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/keyboard_row_spacing" />

    <!-- Row 5: Navigation buttons -->
    <LinearLayout
        android:id="@+id/keyboard_row_5"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_nav_home"
            android:layout_width="@dimen/keyboard_back_button_width"
            android:layout_height="@dimen/keyboard_key_height"
            android:layout_gravity="center_vertical"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin"
            android:background="@drawable/bg_outline_button"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:text="@string/tab_claude"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/keyboard_key_text_size" />

        <TextView
            android:id="@+id/btn_nav_touchpad"
            android:layout_width="@dimen/keyboard_back_button_width"
            android:layout_height="@dimen/keyboard_key_height"
            android:layout_gravity="center_vertical"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin"
            android:background="@drawable/bg_outline_button"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:text="@string/tab_touchpad"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/keyboard_key_text_size" />

    </LinearLayout>

</LinearLayout>
